# ============================================================
-- ARQUIVO DE CONFIGURAÇÃO DE AMBIENTE — VITE + SUPABASE
-- Substitua os valores abaixo com as credenciais do seu projeto
-- ============================================================

# URL do seu projeto no Supabase (ex: https://abcde12345.supabase.co)
VITE_SUPABASE_URL=https://seu-projeto-id.supabase.co

# Chave pública anônima (encontrada em Settings > API no Supabase)
VITE_SUPABASE_ANON_KEY=cole-sua-chave-anon-public-aqui-xxxxxxxxxxxxxxxx
